{
  "name": "just-clipboard-manager",
  "version": "4.0.0",
  "description": "Just a clipboard manager.",
  "author": {
    "name": "Yevheniy Tymchishin",
    "email": "timchishinevgeniy@gmail.com"
  },
  "license": "MIT",
  "main": "./dist/main.js",
  "scripts": {
    "electron": "npm run electron-tsc && ng build && electron .",
    "electron-serve": "concurrently \"npm run electron-tsc && ng serve\" \"wait-on tcp:4200 && electron . --serve\"",
    "electron-tsc": "copy-files-from-to && tsc -p tsconfig.electron.json",
    "outdated": "npm outdated",
    "update-packages": "npm update --save",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "copyFiles": [
    {
      "from": "electron/assets/**/*",
      "to": "dist/assets/"
    }
  ],
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.8",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.8",
    "@angular/router": "^18.2.8",
    "rxjs": "~7.8.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.8",
    "@angular/cli": "^18.2.8",
    "@angular/compiler-cli": "^18.2.8",
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@types/jasmine": "~5.1.0",
    "concurrently": "^9.0.1",
    "copy-files-from-to": "^3.11.0",
    "electron": "^33.0.0",
    "jasmine-core": "~5.4",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.2",
    "wait-on": "^8.0.1"
  }
}
